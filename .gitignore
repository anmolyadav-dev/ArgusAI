frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/dist-ssr/
*.local

# --- OS ---
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Logs ---
*.log
logs/

# --- Misc ---
.antigravityignore